# shell-integration = fish

# Font
font-family = "Maple Mono NF CN Bold"
# FiraCode Nerd Font Mono Bold
# LXGW WenKai Mono Medium
# Maple Mono NF CN ExtraBold Italic
font-size = 9
font-thicken = true
font-feature = ss01
font-feature = ss04
font-feature = liga
font-feature = clig
font-feature = calt
adjust-cell-width = 2%
adjust-cell-height = -10%

# bold-is-bright = false
# adjust-box-thickness = 1

# Theme
theme = custom
background-opacity = 0.7

# shaders
# custom-shader = shaders/glow++.glsl
# custom-shader = shaders/starfield-colors.glsl
# custom-shader = shaders/bettercrt.glsl
# custom-shader = shaders/cursor_smear_fade.glsl
# custom-shader = shaders/cursor_frozen.glsl
# custom-shader = shaders/cursor_blaze.glsl
custom-shader = shaders/cursor_smear.glsl
# custom-shader = shaders/cursor_blaze2.glsl
# custom-shader = shaders/tesla_coil.glsl
# custom-shader = shaders/glow.glsl

cursor-color = #FFFFFF
cursor-text = #000000
cursor-style = block
cursor-opacity = 0.7
# cursor-invert-fg-bg
cursor-style-blink = false
adjust-cursor-thickness = 1

resize-overlay = never
copy-on-select = false
confirm-close-surface = false
mouse-hide-while-typing = true

# 设置窗口左右和上下的内边距
window-padding-x = 1
window-padding-y = 1
window-padding-balance = true
window-padding-color = background
window-inherit-working-directory = true
window-inherit-font-size = true
window-decoration = false

gtk-titlebar = false
gtk-single-instance = false
gtk-tabs-location = bottom
gtk-wide-tabs = false

auto-update = off
term = ghostty
clipboard-paste-protection = false

# 解除快捷键绑定
keybind = shift+end=unbind
keybind = shift+home=unbind
keybind = ctrl+shift+left=unbind
keybind = ctrl+shift+right=unbind
# 设置Shift+Enter为插入换行符
keybind = shift+enter=text:\n
