# printf "\n%.0s" {1..1}

# Check if wallpapers directory exists in loneros
if [ -d "loneros/wallpapers" ]; then
  while true; do
    read -p "${CAT} ${ORANGE}wallpapers${RESET} directory found in loneros/. Do you want to use loneros' wallpapers and overwrite your current wallpapers? (y/n): " WALLPAPER_CHOICE
    case "$WALLPAPER_CHOICE" in
    [Yy]*)
      # Create the target directory if it doesn't exist
      if [ ! -d "$HOME/Pictures/wallpapers" ]; then
        echo "${INFO} - Creating $HOME/Pictures/wallpapers directory."
        mkdir -p "$HOME/Pictures/wallpapers"
      fi

      # Backup existing wallpapers (if any)
      if [ -d "$HOME/Pictures/wallpapers" ]; then
        BACKUP_DIR=$(get_backup_dirname)
        mv "$HOME/Pictures/wallpapers" "$HOME/Pictures/wallpapers-backup-$BACKUP_DIR"
        echo "${NOTE} - Existing wallpapers backed up to $HOME/Pictures/wallpapers-backup-$BACKUP_DIR."
      fi

      # Copy new wallpapers
      cp -r loneros/wallpapers "$HOME/Pictures/wallpapers"
      if [ $? -eq 0 ]; then
        echo "${OK} - Wallpapers successfully copied to $HOME/Pictures/wallpapers."
      else
        echo "${ERROR} - Failed to copy wallpapers." 2>&1 | tee -a "$LOG"
        exit 1
      fi
      break
      ;;
    [Nn]*)
      echo "${NOTE} - Skipping wallpaper setup." 2>&1 | tee -a "$LOG"
      break
      ;;
    *)
      echo "${WARN} - Invalid choice. Please enter Y or N."
      ;;
    esac
  done
else
  echo "${NOTE} - No wallpapers directory found in loneros."
fi
printf "\n%.0s" {1..1}

printf "${INFO} - Copying dotfiles ${BLUE}second${RESET} part\n"
