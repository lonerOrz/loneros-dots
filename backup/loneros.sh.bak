#!/usr/bin/env bash

# Check if running as root. If root, script will exit
if [[ $EUID -eq 0 ]]; then
  echo "This script should not be executed as root! Exiting......."
  exit 1
fi

# Print the custom loneros banner
printf "\n%.0s" {1..2}
echo '.__                                                        .___      __          '
echo '|  |   ____   ____   ___________  ____  ______           __| _/_____/  |_  ______'
echo '|  |  /  _ \ /    \_/ __ \_  __ \/  _ \/  ___/  ______  / __ |/  _ \   __\/  ___/'
echo '|  |_(  <_> )   |  \  ___/|  | \(  <_> )___ \  /_____/ / /_/ (  <_> )  |  \___ \ '
echo '|____/\____/|___|  /\___  >__|   \____/____  >         \____ |\____/|__| /____  >'
echo '                 \/     \/                 \/               \/                \/ '
printf "\n%.0s" {1..2}

# Set some colors for output messages
OK="$(tput setaf 2)[OK]$(tput sgr0)"
ERROR="$(tput setaf 1)[ERROR]$(tput sgr0)"
NOTE="$(tput setaf 3)[NOTE]$(tput sgr0)"
INFO="$(tput setaf 4)[INFO]$(tput sgr0)"
WARN="$(tput setaf 5)[WARN]$(tput sgr0)"
CAT="$(tput setaf 6)[ACTION]$(tput sgr0)"
ORANGE=$(tput setaf 166)
YELLOW=$(tput setaf 3)
BLUE=$(tput setaf 4)
RESET=$(tput sgr0)

# Create Directory for Copy Logs
# if [ ! -d loneros-logs ]; then
#   mkdir loneros-logs
# fi

# Function to print colorful text
print_color() {
  printf "%b%s%b\n" "$1" "$2" "$CLEAR"
}

# Set the name of the log file to include the current date and time
LOG="loneros-logs/install-$(date +%d-%H%M%S)_dotfiles.log"

# Run the original copy script from the upstream repository
chmod +x ./*.sh
# echo "${INFO} - Running the original sync script from the upstream repository..."
read -p "${CAT} Do you want to sync config? (y/n): " SYNC
case "$SYNC" in
[Yy]*)
  ./sync.sh
  ;;
[Nn]*)
  echo "${NOTE} - Skipping sync config"
  ;;
*)
  echo "${WARN} - Invalid choice."
  ;;
esac

# Function to create a unique backup directory name with month, day, hours, and minutes
get_backup_dirname() {
  local timestamp
  timestamp=$(date +"%m%d_%H%M")
  echo "back-up_${timestamp}"
}

# Directory for configurations
config_dir="$PWD/loneros"

# Check if stow is installed
if ! command -v stow &>/dev/null; then
  echo -e "$ERROR stow is not installed. Please install it first. $RESET"
  exit 1
fi
echo -e "$OK stow is installed. $RESET"

# 查找配置目录中的子目录
directories=($(find "$config_dir" -mindepth 1 -maxdepth 1 -type d))

mkdir_route() {
  local dirname="$1"

  if [ -f "$config_dir/$dirname/route" ]; then
    echo "检测到 rout 文件，按 rout 规则创建目录..."

    while IFS= read -r line; do
      [[ -z "$line" ]] && continue    # 忽略空行
      [[ "$line" =~ ^# ]] && continue # 忽略注释行

      # 处理提示信息
      if [[ "$line" =~ ^@NOTE ]]; then
        echo "route 提示: ${line#@NOTE: }"
        continue
      fi

      # 处理正常的目录路径
      target_dir="$HOME/$line"
      if [ ! -d "$target_dir" ]; then
        mkdir -p "$target_dir"
        echo " 创建目录: $target_dir 成功！"
      fi
    done <"$config_dir/$dirname/route"
  else
    echo "没有需要创建的文件夹"
  fi
}

# 遍历所有目录
for dir in "${directories[@]}"; do
  dir_name=$(basename "$dir")

  # 开始链接配置文件
  # echo -e "$CAT Linking configuration: ${BLUE} $dir_name $RESET"
  if [ -d "$config_dir/$dir_name" ]; then
    read -p "${CAT} Do you want to stow ${BLUE}$dir_name$RESET ? (y/n): " SYNC
    case "$SYNC" in
    [Yy]*)
      stow_output=$(stow --dir="$config_dir" --target="$HOME" -D "$dir_name" 2>&1)
      mkdir_route "$dir_name"
      stow_output=$(stow --dir="$config_dir" --target="$HOME" "$dir_name" --ignore="^route$" --adopt 2>&1)
      stow_status=$?
      echo -e "$OK $dir_name successfully linked. $RESET"
      ;;
    [Nn]*)
      echo "${NOTE} - Skipping link $dir_name $RESET"
      ;;
    *)
      echo "${WARN} - Invalid choice."
      ;;
    esac
    echo
  else
    echo -e "$ORANGE $config_dir/$dir_name does not exist. Skipping. $RESET"
    echo
  fi
done

